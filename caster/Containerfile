# ─── Artifacts from shared base ──────────────────────────────────────────────
# streamer-base must be built first:  podman build -t streamer-base base/
FROM streamer-base:latest AS base

# ─── Runtime Stage ───────────────────────────────────────────────────────────
FROM registry.access.redhat.com/ubi10/ubi:latest

# ── Repos: Rocky 10 + EPEL10 + RPM Fusion Free (for x264enc) ────────────────
RUN rpm --import https://dl.rockylinux.org/pub/rocky/RPM-GPG-KEY-rockyofficial \
    && rpm --import https://dl.rockylinux.org/pub/rocky/RPM-GPG-KEY-Rocky-10 \
    && printf '%s\n' \
        '[rocky10-baseos]' \
        'name=Rocky Linux 10 - BaseOS' \
        'baseurl=https://dl.rockylinux.org/pub/rocky/10/BaseOS/$basearch/os/' \
        'enabled=1' \
        'gpgcheck=1' \
        'gpgkey=https://dl.rockylinux.org/pub/rocky/RPM-GPG-KEY-rockyofficial' \
        '       https://dl.rockylinux.org/pub/rocky/RPM-GPG-KEY-Rocky-10' \
        'priority=100' \
        '' \
        '[rocky10-appstream]' \
        'name=Rocky Linux 10 - AppStream' \
        'baseurl=https://dl.rockylinux.org/pub/rocky/10/AppStream/$basearch/os/' \
        'enabled=1' \
        'gpgcheck=1' \
        'gpgkey=https://dl.rockylinux.org/pub/rocky/RPM-GPG-KEY-rockyofficial' \
        '       https://dl.rockylinux.org/pub/rocky/RPM-GPG-KEY-Rocky-10' \
        'priority=100' \
        > /etc/yum.repos.d/rocky10-supplement.repo \
    && dnf install -y \
        https://dl.fedoraproject.org/pub/epel/epel-release-latest-10.noarch.rpm \
        https://mirrors.rpmfusion.org/free/el/rpmfusion-free-release-10.noarch.rpm \
    && dnf clean all

# ── GStreamer runtime packages ──────────────────────────────────────────────
# gstreamer1-plugins-good  : ximagesrc (X11 capture), videoconvert, videoscale,
#                            videorate, matroskamux
# gstreamer1-plugins-bad-free : h264parse; base for webrtcbin (overwritten below)
# gstreamer1-plugins-ugly  : x264enc (software H.264 fallback, via RPM Fusion)
# libnice / libsrtp / libsodium : runtime deps for webrtcsink DTLS-SRTP
RUN dnf install -y \
        --setopt=install_weak_deps=False \
        --setopt=tsflags=nodocs \
        gstreamer1 \
        gstreamer1-plugins-base \
        gstreamer1-plugins-good \
        gstreamer1-plugins-bad-free \
        gstreamer1-plugins-ugly \
        openssl-libs \
        libnice \
        libnice-gstreamer1 \
        libsrtp \
        libsodium \
        nmap-ncat \
        python3 \
        python3-gobject \
    && dnf clean all \
    && rm -rf /var/cache/dnf /var/cache/yum /var/log/dnf* \
              /usr/share/doc /usr/share/man /usr/share/info

# ── Rust GStreamer plugins (webrtcsink, webrtcsrc, and friends) ──────────────
COPY --from=base /opt/gst-rs/lib/gstreamer-1.0/ /usr/local/lib/gstreamer-1.0/

# ── nvcodec + libgstcuda ─────────────────────────────────────────────────────
COPY --from=base /opt/gst-nvcodec/lib/gstreamer-1.0/libgstnvcodec.so /usr/local/lib/gstreamer-1.0/
COPY --from=base /opt/gst-nvcodec/lib/libgstcuda-1.0.so* /usr/local/lib/

RUN echo "/usr/local/lib" > /etc/ld.so.conf.d/gst-local.conf && ldconfig

# ── Replace RHEL10's webrtcbin/dtls/sctp/srtp with our libsrtp2+libnice build ─
COPY --from=base /opt/gst-nvcodec/lib/gstreamer-1.0/libgstwebrtc.so /usr/lib64/gstreamer-1.0/libgstwebrtc.so
COPY --from=base /opt/gst-nvcodec/lib/gstreamer-1.0/libgstdtls.so   /usr/lib64/gstreamer-1.0/libgstdtls.so
COPY --from=base /opt/gst-nvcodec/lib/gstreamer-1.0/libgstsctp.so   /usr/lib64/gstreamer-1.0/libgstsctp.so
COPY --from=base /opt/gst-nvcodec/lib/gstreamer-1.0/libgstsrtp.so   /usr/lib64/gstreamer-1.0/libgstsrtp.so
COPY --from=base /opt/gst-nvcodec/lib/libgstwebrtc-1.0.so*     /usr/lib64/
COPY --from=base /opt/gst-nvcodec/lib/libgstwebrtcnice-1.0.so* /usr/lib64/
COPY --from=base /opt/gst-nvcodec/lib/libgstsctp-1.0.so*       /usr/lib64/
RUN ldconfig

# ── Signalling server binary (caster runs its own for the service to connect) ─
COPY --from=base /opt/gst-webrtc-signalling-server /usr/local/bin/gst-webrtc-signalling-server
RUN chmod +x /usr/local/bin/gst-webrtc-signalling-server

# ── Application ─────────────────────────────────────────────────────────────
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY pipeline.py   /usr/local/bin/pipeline.py
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/pipeline.py

# ── Environment defaults ────────────────────────────────────────────────────
ENV GST_PLUGIN_PATH=/usr/local/lib/gstreamer-1.0 \
    DISPLAY=:0 \
    STREAM_WIDTH=1920 \
    STREAM_HEIGHT=1080 \
    STREAM_FRAMERATE=30 \
    SIGNALLING_HOST=0.0.0.0 \
    SIGNALLING_PORT=8443 \
    GST_WEBRTC_STUN_SERVER="" \
    GST_WEBRTC_TURN_SERVER="" \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=video,compute

EXPOSE 8443/tcp

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
